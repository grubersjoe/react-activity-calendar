{
  "name": "react-activity-calendar",
  "version": "3.2.0",
  "description": "React component to display activity data in calendar",
  "author": "Jonathan Gruber <gruberjonathan@gmail.com>",
  "license": "MIT",
  "homepage": "https://grubersjoe.github.io/react-activity-calendar/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grubersjoe/react-activity-calendar.git"
  },
  "exports": {
    ".": "./build/index.js",
    "./tooltips.css": "./build/tooltips.css"
  },
  "type": "module",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "src",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:storybook": "storybook build -o docs/ && touch docs/.nojekyll",
    "bundlesize": "pnpm install && EXTERNAL_DEPS=false pnpm build && open bundle.html",
    "check": "pnpm install --frozen-lockfile --ignore-scripts && pnpm exec prettier -c . && pnpm exec tsgo && pnpm lint && pnpm test:unit",
    "dev": "storybook dev -p 9000",
    "format": "prettier --write .",
    "lint": "eslint .",
    "postbuild": "dts-bundle-generator src/index.tsx -o build/index.d.ts --no-check --no-banner --external-imports react date-fns @floating-ui/react",
    "prebuild": "rm -rf build/*",
    "prepare": "husky",
    "prepublishOnly": "pnpm check && pnpm build",
    "react-docgen": "pnpm dlx @react-docgen/cli src/components/ActivityCalendar.tsx | jq '.[\"src/components/ActivityCalendar.tsx\"][0]'",
    "start": "rollup -c -w",
    "test": "pnpm test:unit && pnpm test:visual",
    "test:unit": "vitest run",
    "test:visual": "docker compose run --build --rm --quiet -p 9001:9001 playwright bash -c 'pnpm i --ignore-scripts && pnpm exec playwright test'",
    "test:visual:update": "docker compose run --build --rm --quiet playwright bash -c 'pnpm i --ignore-scripts && pnpm exec playwright test --update-snapshots'"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tsconfig/bases": "^1.0.23",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vueless/storybook-dark-mode": "^10.0.7",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-docgen": "^8.0.3",
    "react-ga4": "^3.0.1",
    "rollup": "^4.60.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "storybook": "^10.3.5",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version",
    "last 1 safari version"
  ]
}
